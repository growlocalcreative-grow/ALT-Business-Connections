rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is the master admin
    function isMasterAdmin() {
      return request.auth != null && 
             (request.auth.token.email == "growlocalcreative@gmail.com" && 
              request.auth.token.email_verified == true);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Allow user to read and create their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Master admin access
      allow read, write: if isMasterAdmin();
    }

    match /issues/{issueId} {
      allow create: if request.auth != null;
      allow read, write: if isMasterAdmin();
    }

    // Allow general read/write for other collections if authenticated
    match /businesses/{id} { allow read, write: if request.auth != null; }
    match /reviews/{id} { allow read, write: if request.auth != null; }
    match /helpOffers/{id} { allow read, write: if request.auth != null; }
    match /resources/{id} { allow read, write: if request.auth != null; }
    match /events/{id} { allow read, write: if request.auth != null; }
    match /assistanceRequests/{id} { allow read, write: if request.auth != null; }
  }
}
