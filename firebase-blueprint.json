{
  "entities": {
    "User": {
      "title": "User",
      "description": "Resident or business profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["neighbor", "business", "admin", "master-admin"] },
        "streetName": { "type": "string" },
        "anonymousName": { "type": "string" },
        "natureIcon": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName", "role", "streetName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
